{
    "name": "@nexus/menubar-app",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "author": "NEXUS Team",
    "description": "Nexus menu bar MVP for inbox summary and quick pull request actions",
    "main": "./dist/electronMain.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": "./dist/index.js"
    },
    "scripts": {
        "build": "tsc -p ./tsconfig.json",
        "test": "vitest run",
        "start:electron": "electron ./dist/electronMain.js",
        "dev:electron": "pnpm build && electron ./dist/electronMain.js",
        "package:electron:dir": "pnpm build && electron-builder --dir --config electron-builder.yml",
        "package:electron:ci": "pnpm build && electron-builder --config electron-builder.yml"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "electron": "^37.0.0",
        "electron-builder": "^25.1.8",
        "typescript": "^5.7.0",
        "vitest": "^2.1.0"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}
